{
  "name": "nodemailer-mock",
  "version": "2.0.13",
  "description": "Easy as pie nodemailer mock for unit testing your Node.js applications.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doublesharp/nodemailer-mock.git"
  },
  "keywords": [
    "nodemailer",
    "transport",
    "unit test",
    "test",
    "mock",
    "stub",
    "coverage",
    "ci",
    "mocha",
    "jest",
    "typescript"
  ],
  "author": "Justin Silver",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "bugs": {
    "url": "https://github.com/doublesharp/nodemailer-mock/issues"
  },
  "homepage": "https://github.com/doublesharp/nodemailer-mock#readme",
  "main": "./dist/nodemailer-mock.js",
  "module": "./dist/nodemailer-mock.mjs",
  "types": "./dist/nodemailer-mock.d.ts",
  "exports": {
    ".": "./dist/nodemailer-mock.js",
    "./lib/messages": "./dist/lib/messages.js"
  },
  "scripts": {
    "clean": "shx rm -rf ./dist",
    "build": "pnpm run build:tsc && pnpm run build:mjs",
    "build:tsc": "tsc",
    "build:mjs": "cp ./mjs/nodemailer-mock.mjs ./dist/nodemailer-mock.mjs",
    "prepare": "pnpm run clean && pnpm run build",
    "pretest": "pnpm run build",
    "test": "mocha -r ts-node/register",
    "nyc": "nyc pnpm run test",
    "coverage": "pnpm run nyc && pnpm dlx @0xdoublesharp/doublcov@latest build",
    "coverage:noop": "pnpm run coverage -- --no-open",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "quality": "pnpm run lint && pnpm run typecheck && pnpm run knip",
    "inspect": "NODE_ENV=test pnpm run test -- -s 0 --inspect --debug-brk",
    "examples": "pnpm run example:jest && pnpm run example:mocha && pnpm run example:node-test && pnpm run example:vitest",
    "example:jest": "jest examples/__tests__",
    "example:mocha": "cd examples; mocha -r ts-node/register test/mocha-commonjs-example-javascript.js test/mocha-commonjs-example-typescript.ts",
    "example:node-test": "node --experimental-test-module-mocks --test examples/test/node-test-example-javascript.mjs",
    "example:vitest": "vitest run examples/test/vitest-example-javascript.test.mjs"
  },
  "dependencies": {
    "debug": "^4.4.3"
  },
  "peerDependencies": {
    "nodemailer": "^6.x || ^7.x || ^8.x || ^9.x"
  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@jest/globals": "^30.4.1",
    "@types/chai": "^5.2.3",
    "@types/debug": "^4.1.13",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.x",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "chai": "^6.2.2",
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "knip": "^6.17.1",
    "mocha": "^11.7.6",
    "nodemailer": "~9.0.0",
    "nyc": "^18.0.0",
    "shx": "^0.4.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@babel/core": "^7.29.6",
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "^4.2.0"
    },
    "anymatch": {
      "picomatch": "~2.3.2"
    },
    "istanbul-lib-processinfo": {
      "uuid": "~14.0.0"
    },
    "micromatch": {
      "picomatch": "~2.3.2"
    },
    "mocha": {
      "diff": "~8.0.3",
      "js-yaml": "^4.2.0",
      "serialize-javascript": "~7.0.5"
    },
    "ts-node": {
      "diff": "~4.0.4"
    },
    "vite": "^8.0.16"
  },
  "pre-commit": [
    "lint"
  ],
  "pre-push": []
}
