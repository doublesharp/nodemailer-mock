{
  "name": "nodemailer-mock",
  "version": "2.0.10",
  "description": "Easy as pie nodemailer mock for unit testing your Node.js applications.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doublesharp/nodemailer-mock.git"
  },
  "keywords": [
    "nodemailer",
    "transport",
    "unit test",
    "test",
    "mock",
    "stub",
    "coverage",
    "ci",
    "mocha",
    "jest",
    "typescript"
  ],
  "author": "Justin Silver",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/doublesharp/nodemailer-mock/issues"
  },
  "homepage": "https://github.com/doublesharp/nodemailer-mock#readme",
  "main": "./dist/nodemailer-mock.js",
  "module": "./dist/nodemailer-mock.mjs",
  "types": "./dist/nodemailer-mock.d.ts",
  "exports": {
    ".": "./dist/nodemailer-mock.js",
    "./lib/messages": "./dist/lib/messages.js"
  },
  "scripts": {
    "clean": "shx rm -rf ./dist",
    "build": "npm run build:tsc && npm run build:mjs",
    "build:tsc": "tsc",
    "build:mjs": "cp ./mjs/nodemailer-mock.mjs ./dist/nodemailer-mock.mjs",
    "prepare": "npm run clean && npm run build",
    "pretest": "npm run build",
    "test": "mocha -r ts-node/register",
    "nyc": "nyc npm run test",
    "coverage": "npm run nyc && npx --yes @0xdoublesharp/doublcov@latest build",
    "coverage:noop": "npm run coverage -- --no-open",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "quality": "npm run lint && npm run typecheck && npm run knip",
    "inspect": "NODE_ENV=test npm run test -- -s 0 --inspect --debug-brk",
    "examples": "npm run example:jest && npm run example:mocha && npm run example:node-test && npm run example:vitest",
    "example:jest": "jest examples/__tests__",
    "example:mocha": "cd examples; mocha -r ts-node/register test/mocha-commonjs-example-javascript.js test/mocha-commonjs-example-typescript.ts",
    "example:node-test": "node --experimental-test-module-mocks --test examples/test/node-test-example-javascript.mjs",
    "example:vitest": "vitest run examples/test/vitest-example-javascript.test.mjs"
  },
  "dependencies": {
    "debug": "^4.4.3"
  },
  "peerDependencies": {
    "nodemailer": "^6.x || ^7.x || ^8.x"
  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@jest/globals": "^30.3.0",
    "@types/chai": "^5.2.3",
    "@types/debug": "^4.1.13",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.x",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "chai": "^4.5.0",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "knip": "^6.7.0",
    "mocha": "^11.7.5",
    "nodemailer": "~8.0.7",
    "nyc": "^18.0.0",
    "shx": "^0.4.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "~3.14.2"
    },
    "anymatch": {
      "picomatch": "~2.3.2"
    },
    "istanbul-lib-processinfo": {
      "uuid": "~14.0.0"
    },
    "micromatch": {
      "picomatch": "~2.3.2"
    },
    "mocha": {
      "diff": "~8.0.3",
      "js-yaml": "~4.1.1",
      "serialize-javascript": "~7.0.3"
    },
    "ts-node": {
      "diff": "~4.0.4"
    }
  },
  "pre-commit": [
    "lint"
  ],
  "pre-push": []
}
